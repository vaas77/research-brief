OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=tvly-your-key-here

# search: auto (default) | mock | tavily
SEARCH_PROVIDER=auto

# synthesis: template (default) | openai
SYNTHESIS_MODE=template

# fetch: live (default) | snippet
FETCH_MODE=live

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=research-brief

# LangSmith tracing (optional)
LANGSMITH_API_KEY=lsv2-your-key-here
LANGSMITH_PROJECT=research-brief
LANGCHAIN_TRACING_V2=true
